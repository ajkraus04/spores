{
  "name": "spores",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e",
    "verify": "bun run typecheck && bun run test && bun run test:e2e && bun run smoke",
    "spores": "node node_modules/tsx/dist/cli.mjs apps/sporesd/src/cli.ts",
    "doctor": "bun run spores -- doctor",
    "status": "bun run spores -- status",
    "targets": "bun run spores -- targets",
    "recorder-helper": "node node_modules/tsx/dist/cli.mjs apps/recorder-helper/src/index.ts",
    "smoke": "node node_modules/tsx/dist/cli.mjs apps/sporesd/src/smoke.ts",
    "mcp": "node node_modules/tsx/dist/cli.mjs apps/sporesd/src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@spores/fake-recorder": "workspace:*",
    "@spores/schema": "workspace:*",
    "@spores/store": "workspace:*",
    "@types/node": "^24.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.10"
  }
}
