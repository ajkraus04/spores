{
  "name": "spores",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e",
    "verify": "npm run typecheck && npm test && npm run test:e2e && npm run smoke",
    "smoke": "tsx apps/sporesd/src/smoke.ts",
    "mcp": "tsx apps/sporesd/src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.10"
  }
}
